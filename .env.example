# Produktion (Render): eine Zeile PostgreSQL — dann Backend- und Scraper-DB_* ignorieren
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Datenbank (lokal: MySQL / Docker)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=market_mizan
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Backend
PORT=3001
FRONTEND_URL=https://mmizan.com

# Frontend
VITE_API_URL=https://api.mmizan.com
VITE_WHATSAPP_NUMBER=+251941881133
VITE_GOOGLE_MAPS_KEY=your_google_maps_key

# Scraper
SCRAPER_SLEEP_MIN=3
SCRAPER_SLEEP_MAX=8
SCRAPER_TEST_MODE=false
LOG_LEVEL=INFO
