# Pflicht: Detail-LLM überspringen, wenn scraped_at jünger als diese Stunden (z. B. 336 = 14 Tage).
SCRAPER_SKIP_IF_SCRAPED_WITHIN_HOURS=336

# RealEthio URL-Inventar: sitemap (Default) | search | both
# REALETHIO_DISCOVERY_MODE=sitemap
# Optional: eigene Sitemap-URLs (kommagetrennt). Default: realethio + ethiopiarealty (property-sitemap.xml + property-sitemap2.xml)
# REALETHIO_SITEMAP_URLS=https://realethio.com/property-sitemap.xml,https://realethio.com/property-sitemap2.xml,https://ethiopiarealty.com/property-sitemap.xml,https://ethiopiarealty.com/property-sitemap2.xml

# crawl4ai LLM extraction (required for realethio_crawl4ai_scraper)
# OPENAI_API_KEY=sk-...
# Optional: CRAWL4AI_LLM_PROVIDER=openai/gpt-4o-mini

# RealEthio: discovery uses Addis-only search HTML (not /wp-json/).
# Optional: set REALETHIO_SEARCH_URL to pin the exact search (query is reused for page/2/, page/3/, …).
# Example (Addis Ababa, all types — same as built-in default, explicit URL OK):
# REALETHIO_SEARCH_URL=https://realethio.com/search-results/?type%5B%5D=&location%5B%5D=addis-ababa&areas%5B%5D=&bedrooms=&furnished=&bathrooms=&property_id=&min-price=&max-price=&min-area=&max-area=
# REALETHIO_MAX_SEARCH_PAGES=200
# Many search pages in a row can trigger HTTP 503 — retries + slower pacing:
# REALETHIO_SEARCH_MAX_RETRIES=8
# REALETHIO_SEARCH_RETRY_BASE_SEC=10
# REALETHIO_PAGINATION_EXTRA_SLEEP_SEC=8
# If still 503 after retries: continue with URLs collected (default). To abort instead:
# REALETHIO_STRICT_DISCOVERY=true
#
# Full inventory on Render (memory / fewer blocks):
# - Omit --limit in the job command so Orphan-Soft-Delete runs (see run_scraper.py).
# - SCRAPER_BATCH_SIZE=1
# SCRAPER_CONCURRENCY=2
# SCRAPER_BATCH_COOLDOWN_SEC=2
# SCRAPER_BROWSER_TEXT_MODE=true
# SCRAPER_BROWSER_LIGHT_MODE=true
# Optional: shrink HTML sent to the LLM (test one listing first):
# REALETHIO_DETAIL_CSS_SELECTOR=#property-detail-wrap
# Extra Chromium flags (comma-separated), only if you know you need them:
# SCRAPER_CHROMIUM_EXTRA_ARGS=

# Optional: gleiche PostgreSQL wie auf Render (Production-Scraper)
# DATABASE_URL=postgresql://...

# Ohne DATABASE_URL: lokales MySQL (docker-compose), siehe DB_* in config.py
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=market_mizan
# DB_USER=root
# DB_PASSWORD=root
