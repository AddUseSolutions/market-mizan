# Öffentliche API-URL (ohne /api — der Client hängt /api an)
# Lokal:
VITE_API_URL=http://localhost:3001
# Render-Beispiel:
# VITE_API_URL=https://market-mizan-api.onrender.com

# WhatsApp floating button (digits only or with +)
VITE_WHATSAPP_NUMBER=+251941881133

# Google Analytics 4 (create property at https://analytics.google.com )
# Set on the Static Site / build env BEFORE npm run build:
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console HTML-tag verification
# https://search.google.com/search-console → Property mmizan.com → HTML tag
# VITE_GOOGLE_SITE_VERIFICATION=paste_token_here

# Site URL used in sitemap generation
# SITE_URL=https://mmizan.com
# SITEMAP_API_URL=https://market-mizan-api.onrender.com
