# Produktion (Render): PostgreSQL-URL aus dem Dashboard verknüpfen
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Lokal: MySQL (docker-compose) — DATABASE_URL dann weglassen
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=market_mizan
# DB_USER=root
# DB_PASSWORD=root

PORT=3001
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-this-secret
ADMIN_EMAIL=admin@mmizan.local
ADMIN_PASSWORD=admin1234

# --- Kontaktformular: Hostpoint SMTP (offiziell: support.hostpoint.ch → E-Mail settings) ---
# Server: asmtp.mail.hostpoint.ch | Port 587 (STARTTLS) oder 465 (SSL)
CONTACT_TO_EMAIL=mmizan@add-use.ch
MAIL_FROM="Market Mizan <mmizan@add-use.ch>"

SMTP_HOST=asmtp.mail.hostpoint.ch
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mmizan@add-use.ch
# Nie ins Git committen — nur lokal in backend/.env oder Render Dashboard:
SMTP_PASS=your-mailbox-password

# Alternative: eine URL (Passwort URL-encoden: $ → %24, & → %26, # → %23)
# SMTP_URL=smtps://mmizan%40add-use.ch:PASSWORD@asmtp.mail.hostpoint.ch:465
