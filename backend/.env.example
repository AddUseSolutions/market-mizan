# Produktion (Render): PostgreSQL-URL aus dem Dashboard verknüpfen
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Lokal: MySQL (docker-compose) — DATABASE_URL dann weglassen
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=market_mizan
# DB_USER=root
# DB_PASSWORD=root

PORT=3001
FRONTEND_URL=https://mmizan.com
PUBLIC_SITE_URL=https://mmizan.com
JWT_SECRET=change-this-secret
ADMIN_EMAIL=admin@mmizan.local
ADMIN_PASSWORD=admin1234

# --- E-Mail: Hostpoint SMTP (https://support.hostpoint.ch/de/technisches/e-mail/haeufig-gestellte-fragen/e-mail-einstellungen-auf-einen-blick)
# Server: asmtp.mail.hostpoint.ch | Port 587 (STARTTLS, SMTP_SECURE=false) oder 465 (SSL, SMTP_SECURE=true)
CONTACT_TO_EMAIL=hello@mmizan.com
ADMIN_NOTIFY_EMAIL=hello@mmizan.com
MAIL_FROM="Market Mizan <hello@mmizan.com>"

SMTP_HOST=asmtp.mail.hostpoint.ch
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@mmizan.com
# Nie ins Git committen — nur lokal in backend/.env oder Render Dashboard (Secret):
SMTP_PASS=your-mailbox-password

# Alternative: eine URL (Passwort URL-encoden: @ → %40, ! → %21, ? → %3F)
# SMTP_URL=smtps://hello%40mmizan.com:PASSWORD@asmtp.mail.hostpoint.ch:465

# ETB per 1 USD (e.g. 130 = 1 USD costs 130 ETB). Used at listing upload/scrape time.
FX_ETB_USD=130

# OpenAI for scraper + listing title suggestions (optional for title API fallback)
# OPENAI_API_KEY=sk-...
