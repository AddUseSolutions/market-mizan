# Produktion (Render): PostgreSQL-URL aus dem Dashboard verknüpfen
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Lokal: MySQL (docker-compose) — DATABASE_URL dann weglassen
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=market_mizan
# DB_USER=root
# DB_PASSWORD=root

PORT=3001
FRONTEND_URL=http://localhost:5173

# Kontaktformular (E-Mail): Empfänger und SMTP
# Auf Render hostet ihr keinen eigenen Mailserver — einen externen SMTP-Dienst nutzen
# (z. B. Brevo, SendGrid, Mailgun, Resend) oder SMTP des Domain-Providers.
# Standard-Empfänger im Code: mmizan@add-use.ch — optional überschreiben
CONTACT_TO_EMAIL=mmizan@add-use.ch
MAIL_FROM="Market Mizan <noreply@add-use.ch>"

# Variante A: eine URL (viele Provider stellen eine smtp+URL bereit)
# SMTP_URL=smtps://user:pass@smtp.example.com:465

# Variante B: einzelne Felder
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
